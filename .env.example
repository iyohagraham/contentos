# ContentOS — Environment Variables
# Copy to .env.local and fill in what you need. The app runs fully in
# demo/localStorage mode with NO keys; cloud + media features activate as you add keys.
# See ACTIVATION.md for the full go-live runbook.

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE + AUTH (Supabase) — activates projects, persistence, the engine
# pipeline, RAG/skills, and the login gate. VITE_* are build-time (set BEFORE build).
# Get from: Supabase Dashboard → Project Settings → API
# ─────────────────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=                 # public-safe (https://xxx.supabase.co)
VITE_SUPABASE_ANON_KEY=            # public-safe (eyJ...)
SUPABASE_SERVICE_KEY=              # SECRET — server-only, bypasses RLS (server functions)
# SUPABASE_ACCESS_TOKEN=           # SECRET — only for CLI provisioning (sbp_...)

# ─────────────────────────────────────────────────────────────────────────────
# TEXT AI — Kimi (Moonshot) primary, OpenAI fallback + embeddings
# ─────────────────────────────────────────────────────────────────────────────
KIMI_API_KEY=                      # SECRET — primary text AI. https://platform.moonshot.ai/
# MOONSHOT_API_KEY=                # accepted alias for KIMI_API_KEY
OPENAI_API_KEY=                    # SECRET — embeddings (text-embedding-3-small) + text fallback

# ─────────────────────────────────────────────────────────────────────────────
# MEDIA — Runware primary (images/edit/upscale/bg-removal), fal.ai for video+voice
# ─────────────────────────────────────────────────────────────────────────────
RUNWARE_API_KEY=                   # SECRET — primary image provider. https://my.runware.ai/
FAL_KEY=                           # SECRET — video (Wan) + voice (Qwen-3-TTS). https://fal.ai/dashboard/keys
# FAL_AI_API_KEY=                  # accepted alias for FAL_KEY
BLOB_READ_WRITE_TOKEN=             # SECRET — Vercel Blob (asset persistence; auto-set by `vercel blob`)

# ─────────────────────────────────────────────────────────────────────────────
# PUBLISHING (Postiz, self-hosted) — enables real posting + analytics
# See RAILWAY_POSTIZ_DEPLOY.md
# ─────────────────────────────────────────────────────────────────────────────
POSTIZ_URL=
POSTIZ_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL
# ─────────────────────────────────────────────────────────────────────────────
PIXABAY_API_KEY=                   # Music Engine — free background music
# MUSIC_PROVIDER_URL=              # Music Engine — any custom provider ({mood,prompt,duration}->{url})
# MUSIC_PROVIDER_KEY=
YOUTUBE_API_KEY=                   # Channel Intelligence — enriches RSS ingestion with sub/view counts
# SOCIAL_SCRAPER_URL=              # Real IG/TikTok ingestion ({platform,url,max}->{samples})
# SOCIAL_SCRAPER_KEY=
# KOKORO_TTS_SCRIPT=               # local Kokoro TTS script path (defaults ~/.kokoro/kokoro_tts.py)

# External alert delivery (Brand Mode) — all optional; alerts are in-app without these.
# ALERT_WEBHOOK_URL=              # Slack/Discord/Zapier/custom — POST { text, alerts, workspace_id }
# ALERT_WEBHOOK_KEY=
# ALERT_EMAIL_WEBHOOK_URL=        # an HTTP mailer (Resend/SES/Postmark proxy) — POST { to, subject, body }
# ALERT_EMAIL_KEY=
# ALERT_EMAIL_TO=                 # recipient address

# ─────────────────────────────────────────────────────────────────────────────
# CRON (optional)
# ─────────────────────────────────────────────────────────────────────────────
CRON_SECRET=                       # protects cron endpoints (Bearer)
# CRON_MAX_JOBS=                   # agent job-queue cap per tick (default 5)
# CRON_MAX_PROJECTS=               # media-project pipeline advances per tick (default 3)

# ─── Local dev only ───
# PORT=3001
