# ContentOS Environment Variables
# Copy this file to .env.local and fill in the keys you need.
# The app runs fully in demo/localStorage mode with NO keys set.

# ─── AI: Script & strategy generation (Kimi / Moonshot) ───
# Primary key. MOONSHOT_API_KEY is accepted as a fallback alias.
# Get from: https://platform.moonshot.ai/
KIMI_API_KEY=
# MOONSHOT_API_KEY=

# ─── AI: Visual + voiceover generation (fal.ai) ───
# Enables real FLUX visuals and Kokoro TTS instead of demo content.
# Get from: https://fal.ai/dashboard/keys
FAL_AI_API_KEY=

# ─── Social posting (Postiz, self-hosted) ───
# Without these, publishing is disabled. See RAILWAY_POSTIZ_DEPLOY.md.
POSTIZ_URL=
POSTIZ_API_KEY=

# ─── Cloud database + auth (Supabase) ───
# Leave blank to use localStorage (offline, no login). When set, the app
# switches to cloud mode AND enables the login gate (see src/AuthGate.jsx).
# Get from: Supabase Dashboard -> Project Settings -> API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Server-only key for privileged writes (e.g. the scheduled-post cron).
# NEVER expose this to the client. Optional.
# SUPABASE_SERVICE_KEY=

# ─── Cron protection (optional) ───
# Shared secret required by /api/cron/process-scheduled.
# CRON_SECRET=

# ─── Local dev only ───
# PORT=3001
