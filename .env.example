# ContentOS Environment Variables
# Copy this file to .env.local and fill in your API keys

# OpenAI API Key (for script & strategy generation)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# fal.ai API Key (for AI video generation - FLUX, Wan, etc.)
# Get from: https://fal.ai/dashboard/keys
FAL_AI_API_KEY=your_fal_api_key_here

# Optional: ElevenLabs for premium voice cloning
# Get from: https://elevenlabs.io/app/profile
ELEVENLABS_API_KEY=

# Optional: HyperFrames Cloud for video rendering
HYPERFRAMES_API_KEY=

# Database (Supabase)
# Get from: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=
SUPABASE_ANON_KEY=

# App Configuration
NEXT_PUBLIC_APP_NAME=ContentOS
NEXT_PUBLIC_APP_URL=http://localhost:5173